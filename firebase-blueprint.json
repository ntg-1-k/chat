{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores core user identity and presence information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique identifier for the user." },
        "email": { "type": "string", "format": "email", "description": "Email address of the user." },
        "displayName": { "type": "string", "description": "Display name of the user." },
        "photoURL": { "type": "string", "description": "URL to the user's profile image." },
        "status": { "type": "string", "enum": ["online", "offline", "away"], "description": "Current presence status." },
        "lastSeen": { "type": "number", "description": "Timestamp of last activity." }
      },
      "required": ["uid", "email", "displayName", "status", "lastSeen"]
    },
    "Message": {
      "title": "Message",
      "description": "A single communication event within a hub.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "content": { "type": "string" },
        "timestamp": { "type": "number" },
        "hubId": { "type": "string" }
      },
      "required": ["senderId", "senderName", "content", "timestamp", "hubId"]
    },
    "Hub": {
      "title": "Hub",
      "description": "A designated channel or chat room.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "topic": { "type": "string" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["name", "topic"]
    }
  },
  "firestore": {
    "/hubs": {
      "schema": "Hub",
      "description": "Global collection of active hubs."
    },
    "/hubs/{hubId}/messages": {
      "schema": "Message",
      "description": "Messages sent within a specific hub."
    },
    "/users": {
      "schema": "UserProfile",
      "description": "User profiles and presence data."
    }
  }
}
